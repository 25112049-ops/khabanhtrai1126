class LineSegment:
    def __init__(self, *args):
        # Hỗ trợ đa dạng đầu vào (Overloading-like behavior)
        if len(args) == 0:
            self.p1, self.p2 = Point(0, 0), Point(0, 0)
        elif len(args) == 1 and isinstance(args[0], LineSegment):
            self.p1, self.p2 = args[0].p1, args[0].p2
        elif len(args) == 2 and isinstance(args[0], Point):
            self.p1, self.p2 = args[0], args[1]
        elif len(args) == 4:
            self.p1 = Point(args[0], args[1])
            self.p2 = Point(args[2], args[3])
        else:
            raise ValueError("Invalid arguments for LineSegment")

    def __str__(self):
        return f"Line[{self.p1}, {self.p2}]"


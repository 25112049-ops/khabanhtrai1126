class Employee:
    MAX_SALARY = 360000000
    
    def __init__(self, name="", base_salary=0, coefficient=0.0):
        self.__name = name
        self.__base_salary = base_salary
        self.__coefficient = coefficient

    @property
    def name(self):
        return self.__name

    @property
    def coefficient(self):
        return self.__coefficient

    @coefficient.setter
    def title(self, value):
        self.__coefficient = value

    def calculate_salary(self):
        return self.__base_salary * self.__coefficient

    def display_info(self):
        salary = self.calculate_salary()
        print(f"--- Employee Information ---")
        print(f"Name: {self.__name}")
        print(f"Salary: {self.__base_salary} x {self.__coefficient} = {salary:,.0f} VND")

    def increase_coefficient(self, increment):
        """Tách biệt logic kiểm tra và cập nhật, không dùng input() bên trong class"""
        new_salary = self.__base_salary * (self.__coefficient + increment)
        
        if new_salary > self.MAX_SALARY:
            print("Error: Salary exceeds the maximum limit!")
            return False
        
        self.__coefficient += increment
        print(f"Update successful. New coefficient: {self.__coefficient}")
        return True


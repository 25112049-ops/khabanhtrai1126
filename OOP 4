class NhanVien:
    # Hằng số lương tối đa
    LUONG_MAX = 50000000.0  

    def __init__(self, ten_nv, luong_cb, he_so_luong):
        self._ten_nv = ten_nv
        self._luong_cb = luong_cb
        self._he_so_luong = he_so_luong

    # Các phương thức Get và Set
    def get_ten_nv(self): return self._ten_nv
    def set_ten_nv(self, value): self._ten_nv = value

    def get_luong_cb(self): return self._luong_cb
    def set_luong_cb(self, value): self._luong_cb = value

    def get_he_so_luong(self): return self._he_so_luong
    def set_he_so_luong(self, value): self._he_so_luong = value

    # Tính lương
    def tinh_luong(self):
        return self._luong_cb * self._he_so_luong

    # Tăng hệ số lương
    def tang_luong(self, he_so_tang):
        moi_he_so = self._he_so_luong + he_so_tang
        if (self._luong_cb * moi_he_so) > self.LUONG_MAX:
            print("Lỗi: Lương vượt quá mức tối đa cho phép!")
            return False
        self._he_so_luong = moi_he_so
        return True

    # Hiển thị thông tin
    def in_ttin(self):
        print(f"Nhân viên: {self._ten_nv}")
        print(f"Lương cơ bản: {self._luong_cb}")
        print(f"Hệ số lương: {self._he_so_luong}")
        print(f"Tổng lương: {self.tinh_luong()}")




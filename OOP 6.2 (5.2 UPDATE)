from abc import ABC, abstractmethod

# 1. Custom Exception
class GiaKhongHopLe(Exception):
    def __init__(self, gia):
        self.gia = gia
        super().__init__(f"Giá {self.gia} không hợp lệ (phải >= 0)")

# 2. Lớp trừu tượng HangHoa
class HangHoa(ABC):
    def __init__(self, ma, ten, nsx, gia):
        self.__ma = ma
        self.__ten = ten
        self.__nsx = nsx
        self.gia = gia  # Gọi setter để kiểm tra logic giá

    # 3. Đóng gói với @property
    @property
    def ma_hang(self): return self.__ma

    @property
    def ten_hang(self): return self.__ten

    @property
    def gia(self): return self.__gia

    @gia.setter
    def gia(self, v):
        if v < 0: 
            raise GiaKhongHopLe(v)
        self.__gia = v

    # 4. Phương thức trừu tượng
    @abstractmethod
    def loai_hang(self): 
        pass

    def inTTin(self):
        return f"[{self.loai_hang()}] {self.__ma} | {self.__ten} | {self.__gia:,.0f}đ"

    # 5. Dunder methods (Method Overriding)
    def __str__(self): 
        return self.inTTin()

    def __eq__(self, o): 
        return self.__ma == o.__ma

    def __lt__(self, o): 
        return self.__gia < o.__gia

    def __hash__(self): 
        return hash(self.__ma)

# 6. Kế thừa và Đa hình (HangDienMay)
class HangDienMay(HangHoa):
    def __init__(self, ma, ten, nsx, gia, bh, dap, cs):
        super().__init__(ma, ten, nsx, gia)
        self.__bh, self.__dap, self.__cs = bh, dap, cs

    def loai_hang(self): 
        return "Điện máy"

    def inTTin(self): 
        # Override phương thức của lớp cha
        return f"{super().inTTin()} | BH: {self.__bh}th | {self.__dap}V | {self.__cs}W"

# --- Demo sử dụng ---
try:
    ds = [
        HangDienMay("DM01", "Tủ lạnh LG", "LG", 12000000, 24, 220, 150),
        HangDienMay("DM02", "Máy giặt Sony", "Sony", 8500000, 12, 220, 2000)
    ]

    # Sắp xếp nhờ __lt__ (theo giá tăng dần)
    print("Danh sách hàng hóa sau khi sắp xếp:")
    for sp in sorted(ds):
        print(sp)  # Gọi __str__ đa hình

    # 7. Context Manager để lưu file
    with open("kho.txt", "w", encoding="utf-8") as f:
        for sp in ds:
            f.write(str(sp) + "\n")
    print("\nĐã lưu dữ liệu vào file kho.txt thành công.")

except GiaKhongHopLe as e:
    print(f"Lỗi nhập liệu: {e}")
